{
  "name": "@zentjs/zentjs",
  "version": "0.0.5",
  "description": "Framework web minimalista e performático para Node.js",
  "license": "BSD-3-Clause",
  "author": "Walber Vaz <wvs.walber@gmail.com>",
  "type": "commonjs",
  "main": "./dist/zent.js",
  "types": "./dist/zent.d.ts",
  "exports": {
    ".": {
      "types": "./dist/zent.d.ts",
      "require": "./dist/zent.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=24"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/zentjs/zentjs.git"
  },
  "bugs": {
    "url": "https://github.com/zentjs/zentjs/issues"
  },
  "homepage": "https://github.com/zentjs/zentjs#readme",
  "publishConfig": {
    "access": "public"
  },
  "keywords": [
    "zentjs",
    "framework",
    "http",
    "api",
    "nodejs",
    "esm"
  ],
  "scripts": {
    "clean": "rm -rf dist",
    "build": "npm run clean && tsc && npm pack --dry-run",
    "test": "vitest run",
    "test:unit": "vitest run test/unit",
    "test:integration": "vitest run test/integration",
    "test:watch": "vitest watch",
    "test:coverage": "vitest run --coverage",
    "bench": "tsx bench/run-benchmarks.ts",
    "bench:save-baseline": "tsx bench/run-benchmarks.ts --save-baseline",
    "bench:frameworks": "tsx bench/frameworks-bench.ts",
    "prepare": "husky",
    "typecheck": "tsc --noEmit",
    "lint": "eslint . && prettier --check .",
    "lint:fix": "eslint . --fix && prettier --write .",
    "commitlint": "commitlint --from=HEAD~1 --to=HEAD --verbose",
    "prepublishOnly": "npm run build"
  },
  "lint-staged": {
    "*.{js,mjs,cjs,ts,mts}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md,yml,yaml}": [
      "prettier --write"
    ]
  },
  "devDependencies": {
    "@commitlint/cli": "^20.4.3",
    "@commitlint/config-conventional": "^20.4.3",
    "@eslint/js": "10.0.1",
    "@types/node": "^25.3.3",
    "@typescript-eslint/eslint-plugin": "^8.56.1",
    "@typescript-eslint/parser": "^8.56.1",
    "@vitest/coverage-v8": "^4.0.18",
    "autocannon": "^8.0.0",
    "eslint": "10.0.2",
    "eslint-config-prettier": "10.1.8",
    "eslint-plugin-prettier": "5.5.5",
    "eslint-plugin-simple-import-sort": "^12.1.1",
    "express": "^5.2.1",
    "fastify": "^5.8.1",
    "globals": "17.4.0",
    "husky": "^9.1.7",
    "jiti": "^2.6.1",
    "lint-staged": "^16.3.2",
    "prettier": "3.8.1",
    "supertest": "^7.2.2",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.56.1",
    "vitest": "4.0.18"
  }
}
